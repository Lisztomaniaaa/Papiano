{
  "rules": {
    ".read": false,
    ".write": false,

    "roles": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.admin === true"
    },

    "deletedAccounts": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.admin === true)",
        ".write": "auth != null && (auth.uid === $uid || auth.token.admin === true)"
      }
    },

    "papianoOnlineBeta": {
      "users": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && (auth.uid === $uid || auth.token.admin === true)"
        }
      },

      "moderation": {
        ".read": "auth != null",
        "$roomId": {
          ".write": "auth != null && (auth.token.admin === true || root.child('papianoOnlineBeta').child('rooms').child($roomId).child('ownerUid').val() === auth.uid)"
        }
      },

      "bans": {
        ".read": "auth != null && auth.token.admin === true",
        ".write": "auth != null && auth.token.admin === true"
      },

      "adminLog": {
        ".read": "auth != null && auth.token.admin === true",
        ".write": "auth != null && auth.token.admin === true"
      },

      "donations": {
        ".read": "auth != null",
        ".write": "auth != null && auth.token.admin === true"
      },

      "rooms":          { ".read": "auth != null", ".write": "auth != null" },
      "roomPlayers":    { ".read": "auth != null", ".write": "auth != null" },
      "roomSeats":      { ".read": "auth != null", ".write": "auth != null" },
      "roomSeatClaims": { ".read": "auth != null", ".write": "auth != null" },
      "roomSlots":      { ".read": "auth != null", ".write": "auth != null" },
      "ownerRooms":     { ".read": "auth != null", ".write": "auth != null" },
      "messages":       { ".read": "auth != null", ".write": "auth != null" },
      "streams":        { ".read": "auth != null", ".write": "auth != null" }
    }
  }
}
