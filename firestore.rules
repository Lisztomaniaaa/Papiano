rules_version = '2';

// DRAFT Firestore rules for Papiano. Closes the privilege-escalation hole the
// audit flagged (a user writing badgeId:'dev' to their own profile to unlock
// admin) and locks reports/donations to admins, while keeping normal profile
// and chat use working. TEST in the Rules Playground / emulator against real
// app flows BEFORE publishing. Requires an 'admin' custom claim on admin
// accounts (see RULES-README.md).

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isAdmin()  { return signedIn() && request.auth.token.admin == true; }

    // Fields a normal user must NOT be able to set on their own profile.
    function touchesPrivileged() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['badgeId', 'roleId', 'ownedRoles']);
    }

    match /profiles/{uid} {
      allow read:   if signedIn();
      allow create: if signedIn() && request.auth.uid == uid;
      // Owner may edit their own profile but NOT the privileged badge/role
      // fields; admins may edit anything.
      allow update: if isAdmin()
                    || (signedIn() && request.auth.uid == uid && !touchesPrivileged());
      allow delete: if isAdmin();

      match /reactions/{voter} {
        allow read:  if signedIn();
        allow write: if signedIn() && request.auth.uid == voter;
      }
    }

    // Sequential public-id counter, claimed inside a signup transaction.
    match /counters/{doc} {
      allow read, write: if signedIn();
    }

    match /chatRooms/{roomId} {
      allow read:          if signedIn();
      allow create, update: if signedIn();
      allow delete:        if isAdmin();

      match /messages/{msgId} {
        allow read:   if signedIn();
        // Author posts as themselves; admins may post/moderate anything.
        allow create: if isAdmin()
                      || (signedIn() && request.resource.data.senderId == request.auth.uid);
        allow update: if isAdmin()
                      || (signedIn() && resource.data.senderId == request.auth.uid);
        allow delete: if isAdmin();
      }
    }

    match /friendships/{pairId} { allow read, write: if signedIn(); }
    match /blocks/{blockId}     { allow read, write: if signedIn(); }

    // Reports: anyone signed-in can file one; only admins can read/resolve.
    match /reports/{reportId} {
      allow create:              if signedIn();
      allow read, update, delete: if isAdmin();
    }

    // Donations: world-readable (in-app leaderboard); admin-only writes.
    match /donations/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }
  }
}
