rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signed() { return request.auth != null; }

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email in [
          'utamairfan44@gmail.com',
          'akunpolos0444000@gmail.com',
          'papianobase@gmail.com'
        ]
      );
    }

    function owns(uid) { return request.auth != null && request.auth.uid == uid; }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function roleAllowed(role) {
      return role == 'common'
        || role == resource.data.get('badgeId', 'common')
        || role == resource.data.get('roleId', 'common')
        || (resource.data.get('ownedRoles', []) is list && role in resource.data.get('ownedRoles', []));
    }

    function badgeWithinInventory() {
      return roleAllowed(request.resource.data.get('badgeId', 'common'))
        && roleAllowed(request.resource.data.get('roleId', 'common'));
    }

    match /profiles/{uid} {
      allow read: if signed();
      allow create: if isAdmin() || (
        owns(uid)
        && request.resource.data.get('badgeId', 'common') == 'common'
        && request.resource.data.get('roleId', 'common') == 'common'
        && request.resource.data.get('ownedRoles', ['common']).hasOnly(['common'])
      );
      allow update: if isAdmin()
        // Playtime sync. NOTE: kept value-unvalidated on purpose — the client
        // pre-marks lastSyncedSeconds before the write, so a single rejected
        // playtime write would wedge the whole session's sync (and multi-device
        // play legitimately writes a lower value than another device). Anti-
        // cheat for playtime needs a server function, not a rule.
        || (owns(uid) && changedKeys().hasOnly(['playTimeSeconds', 'playTime', 'playTimeLeaderboardUpdatedAt', 'updatedAt']))
        // Owner can update most fields. publicId/userId may only be SET once
        // (initial assignment when they don't exist yet); after that they're
        // immutable unless admin writes them.
        || (owns(uid)
            && !changedKeys().hasAny(['ownedRoles', 'likes', 'dislikes'])
            && (
                !changedKeys().hasAny(['publicId', 'userId'])
                || !resource.data.keys().hasAny(['publicId'])
            )
            && badgeWithinInventory())
        // Anyone may cast a like/dislike on another profile, but only by ±1 per
        // write (the client does this in a transaction with a per-voter dedup
        // doc). This stops a direct write from fabricating arbitrary counts.
        || (signed()
            && changedKeys().hasOnly(['likes', 'dislikes', 'updatedAt'])
            && request.resource.data.get('likes', 0) >= 0
            && request.resource.data.get('dislikes', 0) >= 0
            && request.resource.data.get('likes', 0) - resource.data.get('likes', 0) <= 1
            && resource.data.get('likes', 0) - request.resource.data.get('likes', 0) <= 1
            && request.resource.data.get('dislikes', 0) - resource.data.get('dislikes', 0) <= 1
            && resource.data.get('dislikes', 0) - request.resource.data.get('dislikes', 0) <= 1);
      allow delete: if isAdmin();

      match /reactions/{voterUid} {
        allow read: if signed();
        allow write: if owns(voterUid);
      }
    }

    match /counters/{docId} {
      allow read: if signed();
      allow create: if signed()
        && request.resource.data.get('next', 0) is int
        && request.resource.data.get('next', 0) >= 1;
      allow update: if signed()
        && request.resource.data.get('next', 0) is int
        && request.resource.data.get('next', 0) == resource.data.get('next', 0) + 1;
    }

    match /displayNames/{nameKey} {
      allow read: if signed();
      allow create: if signed() && request.resource.data.uid == request.auth.uid;
      allow update: if signed() && resource.data.uid == request.auth.uid;
      allow delete: if signed() && resource.data.uid == request.auth.uid;
    }

    match /chatRooms/{roomId} {
      allow read: if signed();
      allow create: if isAdmin()
        || (signed() && roomId.matches('^group_.*'))
        || (signed() && roomId.matches('^dm_.*')
            && request.auth.uid in request.resource.data.get('participants', []));
      // DM rooms re-send participants in the caller's own order ([me, them]),
      // so the two members write different array orders — don't lock the
      // participants field or the second member's writes would be rejected.
      // Gate instead on the caller already being a member of the room.
      allow update: if isAdmin()
        || (signed() && roomId.matches('^group_.*')
            && !changedKeys().hasAny(['type']))
        || (signed() && roomId.matches('^dm_.*')
            && request.auth.uid in resource.data.get('participants', []));
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if signed();
        allow create: if isAdmin() || request.resource.data.senderId == request.auth.uid;
        allow update: if isAdmin()
          || (signed() && resource.data.senderId == request.auth.uid
              && !changedKeys().hasAny(['senderId', 'createdAt']))
          || (signed() && changedKeys().hasOnly(['hiddenFor', 'updatedAt']));
        allow delete: if isAdmin() || (signed() && resource.data.senderId == request.auth.uid);
      }
    }

    match /friendships/{pairId} {
      allow read: if signed() && (
        resource == null
        || request.auth.uid in resource.data.users
        || resource.data.receiverId == request.auth.uid
        || resource.data.requesterId == request.auth.uid
      );
      allow create: if signed()
        && request.auth.uid in request.resource.data.users
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.status == 'pending';
      // Either party can read/update an existing friendship, but only the
      // RECEIVER can transition status: pending -> accepted. Either party can
      // change to other states (rejected/cancelled) or leave status untouched.
      allow update: if signed() && request.auth.uid in resource.data.users && (
        !changedKeys().hasAny(['status'])
        || request.resource.data.status != 'accepted'
        || resource.data.status == 'accepted'
        || request.auth.uid == resource.data.receiverId
      );
      allow delete: if signed() && (resource == null || request.auth.uid in resource.data.users);
    }

    match /blocks/{blockId} {
      allow read: if signed() && (
        resource == null
        || resource.data.blockerId == request.auth.uid
        || resource.data.blockedId == request.auth.uid
      );
      allow create: if signed() && request.resource.data.blockerId == request.auth.uid;
      allow update: if signed() && resource.data.blockerId == request.auth.uid;
      allow delete: if signed() && (resource == null || resource.data.blockerId == request.auth.uid);
    }

    match /reports/{reportId} {
      allow create: if signed();
      allow read: if isAdmin() || (signed() && (resource == null || resource.data.reporterId == request.auth.uid));
      allow update, delete: if isAdmin();
    }

    match /donations/{donationId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
